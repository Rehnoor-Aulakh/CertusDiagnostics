# Local development configuration. Copy to .env and use real values there.
# In production, set these as environment variables in your hosting provider.
DB_URL=jdbc:postgresql://localhost:5432/certus
DB_USERNAME=your_database_user
DB_PASSWORD=replace_with_a_strong_database_password
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_email@example.com
MAIL_PASSWORD=replace_with_your_email_app_password
# Generate with: openssl rand -base64 32
APP_JWT_SECRET=replace_with_a_32_byte_base64_secret
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
SUPER_ADMIN_EMAIL=admin@example.com
SERVER_PORT=8080
APP_TIME_ZONE=Asia/Kolkata
