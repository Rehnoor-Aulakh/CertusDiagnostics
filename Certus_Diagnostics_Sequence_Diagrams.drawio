          <mxGeometry x="360" y="40" width="120" height="140" as="geometry" />
        </mxCell>
        <mxCell id="upload-api" value="Upload API&lt;br&gt;upload.php" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="api-layer">
          <mxGeometry x="500" y="40" width="120" height="140" as="geometry" />
        </mxCell>
        
        <!-- Business Logic -->
