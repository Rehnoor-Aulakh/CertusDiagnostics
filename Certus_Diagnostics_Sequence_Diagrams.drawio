        </mxCell>

        <!-- Messages -->
        <mxCell id="msg1" value="1: Click Sign In with Google" style="endArrow=classic;html=1;rounded=0;" edge="1" parent="1">
          <mxGeometry width="50" height="50" relative="1" as="geometry">
            <mxPoint x="55" y="140" as="sourcePoint" />
