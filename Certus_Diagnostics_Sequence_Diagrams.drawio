          <mxGeometry x="600" y="310" width="250" height="120" as="geometry" />
        </mxCell>
        <mxCell id="alt-label1" value="[User exists]" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;" vertex="1" parent="1">
          <mxGeometry x="610" y="320" width="100" height="20" as="geometry" />
        </mxCell>
        <mxCell id="msg9" value="9: Return user data" style="endArrow=classic;html=1;rounded=0;dashed=1;" edge="1" parent="1">
